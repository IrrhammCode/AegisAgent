# Aegis Agent Configuration
# ========================
# Copy this to .env and fill in your values.

# ─── Ethereum (Sepolia) ──────────────────────────────────────
# ERC-8004 Identity Registry: 0xf66e7CBdAE1Cb710fee7732E4e1f173624e137A7
# ERC-8004 Reputation Registry: 0x6E2a285294B5c74CB76d76AB77C1ef15c2A9E407
# ERC-8004 Validation Registry: 0xC26171A3c4e1d958cEA196A5e84B7418C58DCA2C
ETH_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
OPERATOR_PRIVATE_KEY=0x...
ERC8004_REGISTRY=0xf66e7CBdAE1Cb710fee7732E4e1f173624e137A7

# ─── Arweave (Irys) ──────────────────────────────────────────
IRYS_NODE=https://devnet.irys.xyz
IRYS_TOKEN=ethereum

# ─── Hypercerts & ATProto ───────────────────────────────────
HYPERCERTS_ENV=test
# Your Bluesky handle (e.g. irham.bsky.social)
ATP_HANDLE=yourname.bsky.social
# IMPORTANT: Use an 'App Password' from Bluesky Settings -> App Passwords
ATP_PASSWORD=your-app-password
ATP_PDS_URL=https://bsky.social

# ─── Agent Runtime ───────────────────────────────────────────
MAX_COMPUTE_BUDGET=10.0
STORAGE_DIRECTORY=./vault_data
ARCHIVE_DIRECTORY=./vault_data_archived
MAX_TASKS_PER_CYCLE=10
HEARTBEAT_SECONDS=30
MAX_RUNTIME_MINUTES=60
TS_NODE_TIMEOUT=120

# ─── Local Machine Auto-Discovery ────────────────────────────
# Comma-separated list of directories to watch in real-time.
# When a new file is detected in these folders, the agent will 
# automatically boot up, scan, and protect it.
# Example: /Users/irham/Documents,/Users/irham/Desktop,./vault_data
SCAN_DIRECTORIES=./vault_data

# Maximum file size to scan (bytes). Default: 5MB
MAX_SCAN_FILE_SIZE=5242880

# ─── GitHub Scanning ────────────────────────────────────────
# Your GitHub personal access token (classic or fine-grained)
GITHUB_TOKEN=ghp_your_token_here

# Comma-separated list of repos to scan (owner/repo format)
# Example: irham/my-private-repo,irham/another-repo
GITHUB_REPOS=
