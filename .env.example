# Aegis Agent Configuration
# ========================
# Copy this to .env and fill in your values.

# ─── Ethereum (Sepolia) ──────────────────────────────────────
# ERC-8004 Identity Registry: 0xf66e7CBdAE1Cb710fee7732E4e1f173624e137A7
# ERC-8004 Reputation Registry: 0x6E2a285294B5c74CB76d76AB77C1ef15c2A9E407
# ERC-8004 Validation Registry: 0xC26171A3c4e1d958cEA196A5e84B7418C58DCA2C
ETH_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
OPERATOR_PRIVATE_KEY=0x...
ERC8004_REGISTRY=0xf66e7CBdAE1Cb710fee7732E4e1f173624e137A7

# ─── Arweave (Irys) ──────────────────────────────────────────
IRYS_NODE=https://devnet.irys.xyz
IRYS_TOKEN=ethereum

# ─── Impulse AI ──────────────────────────────────────────────
IMPULSE_API_KEY=imp_...
IMPULSE_ENDPOINT=https://inference.impulselabs.ai/infer
IMPULSE_DEPLOYMENT_ID=your-deployment-id

# ─── Hypercerts ──────────────────────────────────────────────
HYPERCERTS_ENV=test

# ─── Agent Runtime ───────────────────────────────────────────
MAX_COMPUTE_BUDGET=10.0
STORAGE_DIRECTORY=./vault_data
ARCHIVE_DIRECTORY=./vault_data_archived
MAX_TASKS_PER_CYCLE=10
HEARTBEAT_SECONDS=30
MAX_RUNTIME_MINUTES=60
TS_NODE_TIMEOUT=120
